# Cloud VM Environment — .env.cloud.template
# ============================================
# Copy this file to .env on the Oracle Cloud VM and fill in real values.
# DO NOT commit the real .env — this template file is safe to commit.

# ── Anthropic (required for Cloud agent reasoning) ───────────────────────────
ANTHROPIC_API_KEY=

# ── Agent identity ────────────────────────────────────────────────────────────
AGENT_ID=cloud
VAULT_ROOT=/opt/ai-employee

# ── Gmail (Cloud agent reads email — Local sends) ─────────────────────────────
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_CREDENTIALS_PATH=.claude/gmail_credentials.json

# ── Social media (Cloud drafts — Local posts) ────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCOUNT_ID=
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ── Odoo (Cloud reads — Local writes after approval) ─────────────────────────
ODOO_URL=https://ai-employee.duckdns.org
ODOO_DB=odoo_prod
ODOO_USERNAME=api_user
ODOO_PASSWORD=

# ── Git sync ──────────────────────────────────────────────────────────────────
GIT_REMOTE=origin
GIT_BRANCH=main
# GitHub Personal Access Token or SSH key configured on VM
GITHUB_TOKEN=

# ── DuckDNS (auto-update IP cron) ────────────────────────────────────────────
DUCKDNS_TOKEN=
DUCKDNS_DOMAIN=ai-employee

# ── Safety defaults ───────────────────────────────────────────────────────────
DRY_RUN=false
